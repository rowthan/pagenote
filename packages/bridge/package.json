{
  "name": "@pagenote/bridge",
  "version": "1.1.2",
  "description": "pagenote API bridge",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "echo 'ignore'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "typescript",
    "lib"
  ],
  "author": "rowthan",
  "license": "MIT",
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@types/chrome": "0.0.256"
  }
}
