{
  "name": "@pagenote/shared",
  "version": "1.15.1-dev.3",
  "description": "",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./extApi": {
      "types": "./dist/extApi.d.ts",
      "import": "./dist/extApi.js",
      "require": "./dist/extApi.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js",
      "require": "./dist/utils/index.js"
    },
    "./pagenote-setting": {
      "types": "./dist/pagenote-setting/index.d.ts",
      "import": "./dist/pagenote-setting/index.js",
      "require": "./dist/pagenote-setting/index.js"
    },
    "./pagenote-api": {
      "types": "./dist/pagenote-api/index.d.ts",
      "import": "./dist/pagenote-api/index.js",
      "require": "./dist/pagenote-api/index.js"
    },
    "./pagenote-appstores": {
      "types": "./dist/pagenote-appstores/index.d.ts",
      "import": "./dist/pagenote-appstores/index.js",
      "require": "./dist/pagenote-appstores/index.js"
    },
    "./pagenote-brush": {
      "types": "./dist/pagenote-brush/index.d.ts",
      "import": "./dist/pagenote-brush/index.js",
      "require": "./dist/pagenote-brush/index.js"
    },
    "./pagenote-constant": {
      "types": "./dist/pagenote-constant/index.d.ts",
      "import": "./dist/pagenote-constant/index.js",
      "require": "./dist/pagenote-constant/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "require": "./dist/*.js"
    },
    "./**": {
      "types": "./dist/**/*.d.ts",
      "import": "./dist/**/*.js",
      "require": "./dist/**/*.js"
    }
  },
  "scripts": {
    "prepare": "yarn run build",
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "publish-npm": "npm run build && npm publish --access public",
    "test": "echo \"skip mocha\"",
    "lint": "echo \"skip\""
  },
  "dependencies": {
    "@pagenote/bridge": "^1.1.4-dev.0",
    "colord": "^2.9.3",
    "lodash": "^4.17.23",
    "md5": "^2.3.0",
    "mustache": "^4.2.0"
  },
  "devDependencies": {
    "@types/chrome": "0.0.177",
    "@types/md5": "^2.3.2",
    "@types/mocha": "^9.0.0",
    "@types/mustache": "^4.1.2",
    "@types/node": "^18.11.16",
    "@types/wicg-file-system-access": "^2020.9.5",
    "assert": "^2.0.0",
    "mocha": "^9.2.2",
    "ts-node": "^9.1.1",
    "tslint": "^6.1.3",
    "typescript": "^5.3.3"
  },
  "files": [
    "dist/**/*"
  ],
  "author": "",
  "license": "ISC"
}
